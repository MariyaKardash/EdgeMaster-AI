{
  "name": "edgemaster-ai",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "bundle:holepunch": "bare-pack --host ios-arm64 --host ios-arm64-simulator --host android-arm64 --host android-arm --host android-x64 --linked --out ./src/lib/holepunch/bare/p2p.bundle.js ./src/lib/holepunch/bare/p2p-runtime.js",
    "preandroid": "npm run bundle:holepunch",
    "preios": "npm run bundle:holepunch",
    "start": "npx kill-port 8081 && EXPO_NO_QR_CODE=1 expo start --dev-client --localhost",
    "start:diagnose": "EXPO_USE_METRO_REQUIRE=1 expo start --dev-client --clear",
    "android": "REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1 expo run:android --device",
    "android:release": "expo run:android --variant release --device",
    "ios": "expo run:ios",
    "ios:release": "expo run:ios --configuration Release --device",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "lint": "expo lint",
    "lint:fix": "expo lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepare": "husky",
    "artifacts": "bash scripts/collect-artifacts.sh",
    "artifacts:info": "bash scripts/collect-artifacts.sh --info",
    "artifacts:release": "bash scripts/collect-artifacts.sh --release"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.4.0",
    "@qvac/sdk": "^0.12.2",
    "b4a": "^1.8.1",
    "babel-preset-expo": "~56.0.0",
    "bare-pack": "^2.1.2",
    "corestore": "^7.10.1",
    "expo": "~56.0.9",
    "expo-audio": "~56.0.12",
    "expo-build-properties": "~56.0.18",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.19",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.6",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.10",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "hyperbee": "^2.27.3",
    "hypercore": "^11.33.1",
    "hyperswarm": "^4.17.0",
    "mobx": "^6.16.1",
    "mobx-react-lite": "^4.1.1",
    "react": "19.2.3",
    "react-hook-form": "^7.78.0",
    "react-native": "0.85.3",
    "react-native-b4a": "^0.1.0",
    "react-native-bare-kit": "^0.14.3",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-unistyles": "^3.2.5",
    "react-native-uuid": "^2.0.4",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-native/jest-preset": "0.85.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "bare-pack": "^2.0.1",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8"
  }
}
