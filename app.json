{
  "expo": {
    "name": "EdgeMaster AI",
    "slug": "edgemaster-ai",
    "scheme": "edgemaster-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-dev-client",
      "expo-font",
      "expo-image",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29
          },
          "ios": {
            "usePrecompiledModules": false
          },
          "newArchEnabled": true
        }
      ],
      [
        "react-native-edge-to-edge/app.plugin.js",
        {
          "android": {
            "parentTheme": "Default",
            "enforceNavigationBarContrast": false
          }
        }
      ],
      "expo-router",
      "@qvac/sdk/expo-plugin",
      "expo-splash-screen",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow EdgeMaster AI to access your microphone for voice dictation."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edgemaster.ai",
      "appleTeamId": "9J49H92WB6"
    },
    "android": {
      "package": "com.edgemaster.ai",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "experiments": {
      "tsconfigPaths": true
    }
  }
}
